---
import { Image } from "astro:assets";
import { site } from "../config";
import SocialLinks from "./SocialLinks.astro";
import logo from "../assets/logo.png";

const year = new Date().getFullYear();
---

<footer class="border-t border-white/10 bg-navy-950 text-navy-100">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 sm:grid-cols-2 lg:grid-cols-4">
    <div class="sm:col-span-2 lg:col-span-1">
      <div class="flex items-center gap-2">
        <Image src={logo} alt={`${site.name} logo`} width={44} height={44} class="h-10 w-10" />
        <span class="font-display text-xl font-bold tracking-wide text-white">{site.name}</span>
      </div>
      <p class="mt-4 max-w-xs text-sm text-navy-100/80">{site.description}</p>
    </div>

    <div>
      <h3 class="font-display text-sm font-bold uppercase tracking-wider text-ice-300">Explore</h3>
      <ul class="mt-4 space-y-2 text-sm">
        {site.nav.map((item) => (
          <li>
            <a href={item.href} class="text-navy-100/80 transition hover:text-white">{item.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="font-display text-sm font-bold uppercase tracking-wider text-ice-300">Contact</h3>
      <ul class="mt-4 space-y-2 text-sm">
        <li><a href={`mailto:${site.email}`} class="text-navy-100/80 transition hover:text-white">{site.email}</a></li>
        <li><a href={site.phoneHref} class="text-navy-100/80 transition hover:text-white">{site.phone}</a></li>
        <li class="text-navy-100/80">{site.region}</li>
      </ul>
    </div>

    <div>
      <h3 class="font-display text-sm font-bold uppercase tracking-wider text-ice-300">Follow Us</h3>
      <SocialLinks class="mt-4" />
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-2 px-4 py-5 text-xs text-navy-100/60 sm:flex-row">
      <p>&copy; {year} {site.name}. All rights reserved.</p>
      <a href="/terms" class="transition hover:text-white">Terms</a>
    </div>
  </div>
</footer>
