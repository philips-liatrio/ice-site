---

<div class={`flex items-center gap-3 ${className}`}>
  {
    links.map((l) => (
      <a
        href={l.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={l.name}
        class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 text-white transition hover:bg-ice-500 hover:text-navy-950"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
          <path d={l.path} />
        </svg>
      </a>
    ))
  }
</div>
