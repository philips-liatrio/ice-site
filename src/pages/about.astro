---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";

const values = [
  {
    title: "Skill Advancement",
    body: "We develop players and help them progress to higher competitive levels of the game.",
  },
  {
    title: "Teamwork & Relationships",
    body: "We build lasting relationships and a culture of teamwork among our athletes.",
  },
  {
    title: "Affordability",
    body: "Elite development should be accessible. We work to keep Ice within reach for families.",
  },
  {
    title: "Christ-Centered Coaching",
    body: "Our knowledgeable, collegiate-experienced staff mentor players in a Christ-like environment.",
  },
];
---

<Layout title="About" description="Ice Baseball develops dynamic competitors on and off the field through superior coaching in a Christ-centered environment.">
  <PageHeader
    title="About Ice Baseball"
    subtitle="Excellence in all that we do."
  />

  <section class="mx-auto max-w-3xl px-4 py-16">
    <p class="text-lg leading-relaxed text-navy-700">
      Ice Baseball exists to cultivate <strong>dynamic competitors on and off the field</strong>
      through superior coaching in a Christ-like environment. We are committed to
      developing skilled, well-rounded athletes — and even better people.
    </p>
    <p class="mt-6 text-lg leading-relaxed text-navy-700">
      Our coaches bring collegiate playing and coaching experience, and they are
      deeply committed to each player's growth. We focus on skill advancement,
      building strong relationships, and keeping the game affordable and
      accessible for families across East Tennessee.
    </p>
  </section>

  <section class="bg-navy-50/50">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <h2 class="font-display text-3xl font-bold text-navy-900">What We Value</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2">
        {
          values.map((v) => (
            <div class="rounded-2xl border border-navy-100 bg-white p-7">
              <h3 class="font-display text-xl font-bold text-navy-900">{v.title}</h3>
              <p class="mt-2 text-navy-700/80">{v.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
