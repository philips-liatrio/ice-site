---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import SocialLinks from "../components/SocialLinks.astro";
import { site } from "../config";

const configured = site.formspreeId !== "your-formspree-id";
const endpoint = `https://formspree.io/f/${site.formspreeId}`;
---

<Layout title="Contact" description="Get in touch with Ice Baseball — questions about tryouts, teams, or gear.">
  <PageHeader
    title="Contact Us"
    subtitle="If you have any questions, interests, or concerns, please don't hesitate to reach out."
  />

  <section class="mx-auto grid max-w-6xl gap-10 px-4 py-16 lg:grid-cols-2">
    <!-- Contact details -->
    <div>
      <h2 class="font-display text-2xl font-bold text-navy-900">Get in touch</h2>
      <p class="mt-3 text-navy-700/80">
        Reach us directly, send a message, or follow along on social media.
      </p>

      <div class="mt-8 space-y-5">
        <a href={`mailto:${site.email}`} class="flex items-center gap-4 group">
          <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-navy-900 text-ice-300">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-10 5L2 7"></path></svg>
          </span>
          <span>
            <span class="block text-sm text-navy-700/60">Email</span>
            <span class="font-semibold text-navy-900 group-hover:text-ice-600">{site.email}</span>
          </span>
        </a>

        <a href={site.phoneHref} class="flex items-center gap-4 group">
          <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-navy-900 text-ice-300">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"></path></svg>
          </span>
          <span>
            <span class="block text-sm text-navy-700/60">Phone</span>
            <span class="font-semibold text-navy-900 group-hover:text-ice-600">{site.phone}</span>
          </span>
        </a>
      </div>

      <div class="mt-8">
        <p class="font-display text-sm font-bold uppercase tracking-wider text-navy-700">Follow us on social media!</p>
        <div class="mt-3 inline-flex rounded-xl bg-navy-900 px-4 py-3">
          <SocialLinks />
        </div>
      </div>
    </div>

    <!-- Contact form -->
    <div class="rounded-2xl border border-navy-100 bg-navy-50/50 p-8">
      <form
        id="contact-form"
        action={endpoint}
        method="POST"
        data-configured={String(configured)}
        data-email={site.email}
        class="space-y-5"
      >
        <div>
          <label for="name" class="block text-sm font-semibold text-navy-700">Name</label>
          <input id="name" name="name" type="text" required
            class="mt-1.5 w-full rounded-lg border border-navy-200 bg-white px-4 py-2.5 outline-none focus:border-ice-500 focus:ring-2 focus:ring-ice-200" />
        </div>
        <div>
          <label for="email" class="block text-sm font-semibold text-navy-700">Email</label>
          <input id="email" name="email" type="email" required
            class="mt-1.5 w-full rounded-lg border border-navy-200 bg-white px-4 py-2.5 outline-none focus:border-ice-500 focus:ring-2 focus:ring-ice-200" />
        </div>
        <div>
          <label for="subject" class="block text-sm font-semibold text-navy-700">Subject</label>
          <input id="subject" name="subject" type="text"
            class="mt-1.5 w-full rounded-lg border border-navy-200 bg-white px-4 py-2.5 outline-none focus:border-ice-500 focus:ring-2 focus:ring-ice-200" />
        </div>
        <div>
          <label for="message" class="block text-sm font-semibold text-navy-700">Message</label>
          <textarea id="message" name="message" rows="5" required
            class="mt-1.5 w-full rounded-lg border border-navy-200 bg-white px-4 py-2.5 outline-none focus:border-ice-500 focus:ring-2 focus:ring-ice-200"></textarea>
        </div>

        <button type="submit"
          class="w-full rounded-md bg-ice-500 px-6 py-3 font-display font-semibold uppercase tracking-wide text-navy-950 transition hover:bg-ice-400 disabled:opacity-60">
          Send Message
        </button>

        <p id="form-status" class="hidden text-sm" role="status" aria-live="polite"></p>
      </form>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("form-status");
  if (form && status) {
    const configured = form.dataset.configured === "true";
    const toEmail = form.dataset.email ?? "";

    const setStatus = (msg: string, ok: boolean) => {
      status.textContent = msg;
      status.className = `text-sm ${ok ? "text-green-700" : "text-red-600"}`;
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const name = String(data.get("name") || "");
      const email = String(data.get("email") || "");
      const subject = String(data.get("subject") || "Website inquiry");
      const message = String(data.get("message") || "");

      // Fallback: no Formspree configured yet → open the visitor's email client.
      if (!configured) {
        const body = `From: ${name} <${email}>%0D%0A%0D%0A${encodeURIComponent(message)}`;
        window.location.href = `mailto:${toEmail}?subject=${encodeURIComponent(subject)}&body=${body}`;
        setStatus("Opening your email app… if nothing happens, email us at " + toEmail, true);
        return;
      }

      const btn = form.querySelector("button[type=submit]") as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = "Sending…";
      try {
        const res = await fetch(form.action, {
          method: "POST",
          body: data,
          headers: { Accept: "application/json" },
        });
        if (res.ok) {
          form.reset();
          setStatus("Thanks! Your message has been sent. We'll be in touch soon.", true);
        } else {
          setStatus("Something went wrong. Please email us at " + toEmail + ".", false);
        }
      } catch {
        setStatus("Network error. Please email us at " + toEmail + ".", false);
      } finally {
        btn.disabled = false;
        btn.textContent = "Send Message";
      }
    });
  }
</script>
