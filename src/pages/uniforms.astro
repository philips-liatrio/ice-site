---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import { site } from "../config";
---

<Layout title="Uniforms" description="Uniform ordering for current Ice Baseball members.">
  <PageHeader
    title="Uniforms"
    subtitle="For current Ice Baseball members only."
  />

  <section class="mx-auto max-w-3xl px-4 py-16">
    <div class="rounded-2xl border border-navy-100 bg-white p-8">
      <p class="text-lg text-navy-700">
        Uniform ordering is reserved for current Ice Baseball members. If you're
        on a team this season, here's how to get your gear:
      </p>

      <ol class="mt-6 space-y-4">
        <li class="flex gap-4">
          <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-ice-500 font-display font-bold text-navy-950">1</span>
          <p class="pt-1 text-navy-700/90">Confirm your team and sizing with your coach.</p>
        </li>
        <li class="flex gap-4">
          <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-ice-500 font-display font-bold text-navy-950">2</span>
          <p class="pt-1 text-navy-700/90">Visit the team store to place your uniform order.</p>
        </li>
        <li class="flex gap-4">
          <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-ice-500 font-display font-bold text-navy-950">3</span>
          <p class="pt-1 text-navy-700/90">Questions? Reach out and we'll get you sorted.</p>
        </li>
      </ol>

      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href={site.links.teamShop}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-md bg-ice-500 px-7 py-3 font-display font-semibold uppercase tracking-wide text-navy-950 transition hover:bg-ice-400"
        >
          Go to Team Store
        </a>
        <a
          href="/contact"
          class="rounded-md border border-navy-200 px-7 py-3 font-display font-semibold uppercase tracking-wide text-navy-900 transition hover:bg-navy-50"
        >
          Ask a Question
        </a>
      </div>
    </div>
  </section>
</Layout>
